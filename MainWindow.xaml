<Window x:Class="MDEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MDEditor" Height="650" Width="1100"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseCommand}" />
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding ToggleThemeCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== MENU BAR ===== -->
        <Menu Grid.Row="0" Background="{DynamicResource ToolBarBackground}"
              BorderBrush="{DynamicResource ToolBarBorder}" BorderThickness="0,0,0,1">
            <MenuItem x:Name="MenuFile" Header="File">
                <MenuItem x:Name="MenuNew" Header="Nuovo"
                          Command="{Binding NewCommand}" InputGestureText="Ctrl+N" />
                <MenuItem x:Name="MenuOpen" Header="Apri"
                          Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
                <MenuItem x:Name="MenuSave" Header="Salva"
                          Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem x:Name="MenuSaveAs" Header="Salva con nome..."
                          Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem x:Name="MenuExport" Header="Esporta">
                    <MenuItem x:Name="MenuExportPdf" Header="Esporta come PDF..."
                              Command="{Binding ExportPdfCommand}" />
                    <MenuItem x:Name="MenuExportWord" Header="Esporta come Word..."
                              Command="{Binding ExportWordCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem x:Name="MenuClose" Header="Chiudi scheda"
                          Command="{Binding CloseCommand}" InputGestureText="Ctrl+W" />
                <Separator />
                <MenuItem x:Name="MenuExit" Header="Esci"
                          Click="Exit_Click" InputGestureText="Alt+F4" />
            </MenuItem>

            <MenuItem x:Name="MenuView" Header="Visualizza">
                <MenuItem x:Name="MenuTheme" Header="Tema">
                    <MenuItem x:Name="MenuThemeLight" Header="Chiaro"
                              Click="ThemeLight_Click" IsChecked="{Binding IsLightTheme}" />
                    <MenuItem x:Name="MenuThemeDark" Header="Scuro"
                              Click="ThemeDark_Click" IsChecked="{Binding IsDarkTheme}" />
                </MenuItem>
                <MenuItem x:Name="MenuLanguage" Header="Lingua">
                    <MenuItem x:Name="MenuLangIT" Header="Italiano"
                              Click="LangIT_Click" />
                    <MenuItem x:Name="MenuLangEN" Header="English"
                              Click="LangEN_Click" />
                </MenuItem>
                <Separator />
                <MenuItem x:Name="MenuSwap" Header="Inverti pannelli"
                          Click="SwapPanels_Click" />
            </MenuItem>

            <MenuItem x:Name="MenuHelp" Header="Aiuto">
                <MenuItem x:Name="MenuAbout" Header="Informazioni su MDEditor"
                          Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- ===== TOP TOOLBAR ===== -->
        <ToolBar Grid.Row="1" Padding="4,2" SnapsToDevicePixels="True">
            <ToolBar.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}" />
            </ToolBar.Resources>

            <Button Command="{Binding NewCommand}" x:Name="BtnNew" ToolTip="Nuovo">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📄" FontSize="14" Margin="0,0,4,0" />
                    <TextBlock x:Name="LblNew" Text="Nuovo" />
                </StackPanel>
            </Button>
            <Button Command="{Binding OpenCommand}" x:Name="BtnOpen" ToolTip="Apri">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📂" FontSize="14" Margin="0,0,4,0" />
                    <TextBlock x:Name="LblOpen" Text="Apri" />
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" x:Name="BtnSave" ToolTip="Salva">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾" FontSize="14" Margin="0,0,4,0" />
                    <TextBlock x:Name="LblSave" Text="Salva" />
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <Button Command="{Binding ToggleThemeCommand}" x:Name="BtnTheme" ToolTip="Cambia tema">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🌙" FontSize="14" Margin="0,0,4,0" />
                    <TextBlock Text="Dark" />
                </StackPanel>
            </Button>

            <Button Click="SwapPanels_Click" x:Name="BtnSwap" ToolTip="Inverti editor/preview">
                <TextBlock Text="⇄" FontSize="16" />
            </Button>

            <Button Click="LangToggle_Click" x:Name="BtnLang" ToolTip="Lingua">
                <TextBlock x:Name="LangButton" Text="🇮🇹 IT" FontSize="12" />
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <Button Command="{Binding ExportPdfCommand}" x:Name="BtnExportPdf" ToolTip="Esporta PDF">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📄" FontSize="14" Margin="0,0,4,0" />
                    <TextBlock x:Name="LblExportPdf" Text="PDF" />
                </StackPanel>
            </Button>
            <Button Command="{Binding ExportWordCommand}" x:Name="BtnExportWord" ToolTip="Esporta Word">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📝" FontSize="14" Margin="0,0,4,0" />
                    <TextBlock x:Name="LblExportWord" Text="Word" />
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource ToolbarSeparator}" />

            <TextBlock x:Name="LblView" Text="Vista:" VerticalAlignment="Center" Margin="6,0,4,0" FontSize="12"
                       Foreground="{DynamicResource ForegroundBrush}" Opacity="0.7" />
            <RadioButton Command="{Binding SetViewCommand}" CommandParameter="split"
                         IsChecked="{Binding IsSplitView}" Margin="2,0" FontSize="12">
                <TextBlock x:Name="LblSplit" Text="Split" FontSize="12" />
            </RadioButton>
            <RadioButton Command="{Binding SetViewCommand}" CommandParameter="edit"
                         IsChecked="{Binding IsEditOnly}" Margin="2,0" FontSize="12">
                <TextBlock x:Name="LblEditor" Text="Editor" FontSize="12" />
            </RadioButton>
            <RadioButton Command="{Binding SetViewCommand}" CommandParameter="preview"
                         IsChecked="{Binding IsPreviewOnly}" Margin="2,0" FontSize="12">
                <TextBlock x:Name="LblPreview" Text="Preview" FontSize="12" />
            </RadioButton>
        </ToolBar>

        <!-- ===== TAB BAR ===== -->
        <TabControl x:Name="DocTabs" Grid.Row="2"
                    ItemsSource="{Binding Documents}"
                    SelectedItem="{Binding ActiveDocument}"
                    BorderThickness="0" Padding="0"
                    Background="Transparent">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
                    <Setter Property="Padding" Value="10,3" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="Transparent"
                                        BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="4,4,0,0"
                                        Margin="1,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text=" *"
                                                   Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="Bold" />
                                        <Button Content="✕"
                                                Width="16" Height="16"
                                                FontSize="9"
                                                Margin="6,0,0,0"
                                                Background="Transparent"
                                                Foreground="{DynamicResource ForegroundBrush}"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="CloseTab_Click"
                                                Tag="{Binding}"
                                                VerticalAlignment="Center"
                                                Opacity="0.6" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuItemHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Border Background="{DynamicResource ToolBarBackground}"
                            BorderBrush="{DynamicResource ToolBarBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="4,0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Panel.ZIndex="1" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </TabControl.Template>
        </TabControl>

        <!-- ===== MAIN CONTENT: Editor + Preview ===== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== EDITOR PANEL ===== -->
            <Border x:Name="EditorBorder" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="4,4,2,4" CornerRadius="6" Background="{DynamicResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Editor header -->
                    <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBrush}"
                            CornerRadius="6,6,0,0" Padding="10,5">
                        <TextBlock x:Name="EditorHeaderText" Text="Markdown"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource HeaderForegroundBrush}" />
                    </Border>

                    <!-- ===== FORMATTING TOOLBAR ===== -->
                    <Border Grid.Row="1" Background="{DynamicResource FormatToolbarBackground}"
                            BorderBrush="{DynamicResource FormatToolbarBorder}"
                            BorderThickness="0,1,0,1" Padding="4,2">
                        <WrapPanel x:Name="FormatToolbar">
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip="Grassetto"
                                    Click="FormatBold_Click">
                                <TextBlock Text="B" FontWeight="Bold" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatItalic_Click">
                                <TextBlock Text="I" FontStyle="Italic" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatStrike_Click">
                                <TextBlock Text="S" TextDecorations="Strikethrough" FontSize="13" />
                            </Button>

                            <Separator Style="{StaticResource ToolbarSeparator}" />

                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatH1_Click">
                                <TextBlock Text="H1" FontWeight="Bold" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatH2_Click">
                                <TextBlock Text="H2" FontWeight="Bold" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatH3_Click">
                                <TextBlock Text="H3" FontWeight="Bold" FontSize="11" />
                            </Button>

                            <Separator Style="{StaticResource ToolbarSeparator}" />

                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatUL_Click">
                                <TextBlock Text="•≡" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatOL_Click">
                                <TextBlock Text="1." FontWeight="Bold" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatCheck_Click">
                                <TextBlock Text="☑" FontSize="14" />
                            </Button>

                            <Separator Style="{StaticResource ToolbarSeparator}" />

                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatLink_Click">
                                <TextBlock Text="🔗" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatImage_Click">
                                <TextBlock Text="🖼" FontSize="14" />
                            </Button>

                            <Separator Style="{StaticResource ToolbarSeparator}" />

                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatCode_Click">
                                <TextBlock Text="&lt;/&gt;" FontSize="12" FontFamily="Consolas" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatCodeBlock_Click">
                                <TextBlock Text="{}{ }" FontSize="13" FontFamily="Consolas" />
                            </Button>

                            <Separator Style="{StaticResource ToolbarSeparator}" />

                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatIcon_Click">
                                <TextBlock Text="😀" FontSize="15" />
                            </Button>

                            <Separator Style="{StaticResource ToolbarSeparator}" />

                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatQuote_Click">
                                <TextBlock Text="❝" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatTableDialog_Click">
                                <TextBlock Text="⊞" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatAddRow_Click">
                                <TextBlock Text="⊞⁺" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatAddCol_Click">
                                <TextBlock Text="⊞⁺ᶜ" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource FormatButton}"
                                    ToolTip=""
                                    Click="FormatHR_Click">
                                <TextBlock Text="—" FontSize="14" />
                            </Button>
                        </WrapPanel>
                    </Border>

                    <!-- Editor text area -->
                    <TextBox Grid.Row="2" x:Name="EditorTextBox"
                             Text="{Binding MarkdownText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="14"
                             BorderThickness="0" Margin="8,6"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             SpellCheck.IsEnabled="False"
                             Background="Transparent"
                             Foreground="{DynamicResource EditorForeground}"
                             CaretBrush="{DynamicResource AccentBrush}" />
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter x:Name="MainSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="Transparent"
                          BorderBrush="{DynamicResource SplitterBrush}"
                          BorderThickness="1,0" />

            <!-- ===== PREVIEW PANEL ===== -->
            <Border x:Name="PreviewBorder" Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="2,4,4,4" CornerRadius="6" Background="{DynamicResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource PanelHeaderBrush}"
                            CornerRadius="6,6,0,0" Padding="10,5">
                        <TextBlock x:Name="PreviewHeaderText" Text="Preview"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource HeaderForegroundBrush}" />
                    </Border>
                    <wv2:WebView2 Grid.Row="1" x:Name="PreviewWebView" Margin="0" />
                </Grid>
            </Border>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <StatusBar Grid.Row="4" Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource StatusBarForeground}" />
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}" />
            <StatusBarItem>
                <TextBlock x:Name="VersionLabel" Text="" FontSize="11"
                           Foreground="{DynamicResource StatusBarForeground}" Opacity="0.5" />
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}" />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding FilePath}" FontSize="11"
                           Foreground="{DynamicResource StatusBarForeground}" Opacity="0.7" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
